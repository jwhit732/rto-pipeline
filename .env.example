# Claude API
ANTHROPIC_API_KEY=

# Link tracker (your deployed Vercel instance)
LINK_TRACKER_URL=https://your-tracker.vercel.app
LINK_TRACKER_DEST_URL=https://smartaisolutions.com/demo
CRON_SECRET=

# Google Workspace — email must come from this address via gws
GWS_SEND_FROM=you@yourworkspace.com

# Your first name — used in email sign-off. If blank, Claude writes "[Your Name]".
SENDER_NAME=

# Google Workspace CLI OAuth
GOOGLE_WORKSPACE_CLI_CLIENT_ID=
GOOGLE_WORKSPACE_CLI_CLIENT_SECRET=

# Batch send controls
BATCH_SIZE=50
BATCH_DELAY_MS=2000

# Google Sheets logging (optional — leave blank to skip)
SEND_LOG_SHEET_ID=

# Notifications
DIGEST_TO_EMAIL=jimmy@smartaisolutions.com
